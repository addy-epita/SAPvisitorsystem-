# =============================================================================
# SAP Visitor Management System - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Application Environment
# -----------------------------------------------------------------------------
APP_ENV=production
APP_DEBUG=false

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=visitor_system
DB_USER=visitor_user
DB_PASS=your_secure_password_here

# -----------------------------------------------------------------------------
# Site Configuration
# -----------------------------------------------------------------------------
SITE_URL=https://visitors.yourcompany.com
BASE_URL=https://visitors.yourcompany.com
SITE_NAME=SAP Office
COMPANY_NAME=SAP
TIMEZONE=Europe/Paris
DEFAULT_LANGUAGE=fr

# -----------------------------------------------------------------------------
# Gmail SMTP Configuration (for email notifications)
# Steps to set up:
#   1. Enable 2-Step Verification on your Google account:
#      https://myaccount.google.com/security
#   2. Generate an App Password:
#      https://myaccount.google.com/apppasswords
#      (Select "Mail" and "Other device", name it "SAP Visitor System")
#   3. Paste the 16-character App Password below (spaces are optional)
# -----------------------------------------------------------------------------
GMAIL_FROM_EMAIL=your.gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
GMAIL_FROM_NAME=SAP Visitor System

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your-32-character-encryption-key-here

SESSION_NAME=VMS_Session
SESSION_LIFETIME=1800
SESSION_SECURE=true

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
FEATURE_KIOSK_MODE=true
FEATURE_QR_CHECKOUT=true
FEATURE_EMAIL_NOTIFICATIONS=true
FEATURE_REMINDERS=true
FEATURE_ESCALATION=true
FEATURE_SSO_LOGIN=true
FEATURE_LOCAL_LOGIN=true
FEATURE_DATA_RETENTION=true
FEATURE_AUDIT_LOG=true
FEATURE_MAINTENANCE_MODE=false

# -----------------------------------------------------------------------------
# Optional: Third-party Integrations
# -----------------------------------------------------------------------------
# Twilio SMS (optional)
# TWILIO_ENABLED=false
# TWILIO_SID=your-twilio-sid
# TWILIO_TOKEN=your-twilio-token
# TWILIO_FROM_NUMBER=your-twilio-number

# WhatsApp Business API (optional)
# WHATSAPP_ENABLED=false
# WHATSAPP_API_KEY=your-whatsapp-api-key
